# Copy this to .env and fill in your keys (.env is gitignored).

# Required for the /chat agent's parser + scouting reports (LangGraph + Groq).
# Get a free key at https://console.groq.com/keys
GROQ_API_KEY=

# Required for live player intel (news, injuries, discipline, transfer rumours).
# Gemini 2.5 Pro with Google Search grounding. https://aistudio.google.com/apikey
GEMINI_API_KEY=
# Optional model override (defaults to gemini-2.5-pro)
# GEMINI_MODEL=gemini-2.5-pro
