*.sw?

# Lockfile is intentionally untracked: a Windows-generated lock omits Linux-only
# optional deps (e.g. @emnapi) and breaks `npm ci` on Cloudflare's Linux builders.
# With no lockfile, Cloudflare uses `npm install`, which resolves per-platform deps.
package-lock.json

# wrangler files
.wrangler
.dev.vars*
!.dev.vars.example
.env*
!.env.example
